# ===== מפתחות API =====

# Anthropic (Claude) — המוח של ראובן והצוות
ANTHROPIC_API_KEY=

# יובל (מעצב התמונות) — מפתח לשירות יצירת תמונות
IMAGE_API_KEY=

# חן (החוקרת) — מפתח לשירות חיפוש/מחקר באינטרנט
SEARCH_API_KEY=

# ===== הגדרות כלליות =====

# מודל ברירת המחדל
MODEL=claude-opus-4-8

# רמת לוגים: debug | info | warn | error
LOG_LEVEL=info
